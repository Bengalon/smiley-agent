# ======================================================
# Smiley Agent — קובץ הגדרות
# העתק קובץ זה ל-.env ומלא את הערכים
# ======================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# מי מורשה לדבר עם הבוט (ה-Telegram User ID שלך)
# אפשר לדעת אותו על ידי שליחת הודעה ל-@userinfobot בטלגרם
ALLOWED_TELEGRAM_USER_IDS=123456789

# --- Claude AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Google Drive (Service Account) ---
# הכנס כאן את כל תוכן קובץ ה-JSON של service account (בשורה אחת)
GOOGLE_DRIVE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# --- Higgsfield AI ---
# מפתח API מ-Higgsfield — נמצא ב: higgsfield.ai → Settings → API Keys
HIGGSFIELD_API_KEY=your-higgsfield-api-key-here
